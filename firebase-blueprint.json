{
  "entities": {
    "MenuItem": {
      "title": "Menu Item",
      "description": "An item on the restaurant menu",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the item" },
        "description": { "type": "string", "description": "Description of the item" },
        "price": { "type": "number", "description": "Standard price" },
        "promotionalPrice": { "type": "number", "description": "Promotional price (optional)" },
        "category": { "type": "string", "description": "Category (Especiais, Sanduíches, Simples, Porções, Bebidas)" },
        "image": { "type": "string", "description": "URL of the image" },
        "priceOptions": { "type": "string", "description": "Text describing price variations" }
      },
      "required": ["name", "price", "category"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string" }
      },
      "required": ["role", "email"]
    }
  },
  "firestore": {
    "/menuItems/{itemId}": {
      "schema": { "$ref": "#/entities/MenuItem" },
      "description": "Collection of menu items"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of users for RBAC"
    }
  }
}
